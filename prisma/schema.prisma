// ======================================================
// Prisma Client
// ======================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Enums
// =====================

enum RecipeVisibility {
  PUBLIC
  PRIVATE
}

enum RecipeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeSourceType {
  OWN
  WEBSITE
  VIDEO
  SOCIAL_MEDIA
  SCREENSHOT
  PDF
  BOOK
  OTHER
}

enum ReactionType {
  LIKE
  DISLIKE
}

// =====================
// Users
// =====================

model User {
  id             String  @id @default(cuid())
  email          String  @unique
  name           String?
  shortName      String?
  image          String?
  recipesCount   Int     @default(0)
  favoritesCount Int     @default(0)

  recipes          Recipe[]
  products         Product[]
  favorites        Favorite[]
  comments         Comment[]
  commentReactions CommentReaction[]
  recipeReactions  RecipeReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Recipes
// =====================

model Recipe {
  id          String  @id @default(cuid())
  title       String
  slug        String
  description String?
  notes       String?

  prepTimeSec Int?
  cookTimeSec Int?

  coverImage String?

  visibility RecipeVisibility  @default(PRIVATE)
  difficulty RecipeDifficulty?

  sourceType RecipeSourceType @default(OWN)
  sourceUrl  String?
  sourceName String?

  originalAuthorName String?
  originalAuthorUrl  String?

  calories      Float?
  protein       Float?
  fat           Float?
  carbs         Float?
  glycemicIndex Float?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categories RecipeCategory[]
  tags       RecipeTag[]
  images     RecipeImage[]
  products   RecipeProduct[]
  steps      RecipeStep[]
  favorites  Favorite[]
  comments   Comment[]
  reactions  RecipeReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, slug])
}

// =====================
// Categories / Tags / Allergens
// =====================

model Category {
  id    String  @id @default(cuid())
  title String  @unique
  image String?

  recipes RecipeCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id    String  @id @default(cuid())
  title String  @unique
  image String?

  recipes RecipeTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Allergen {
  id    String  @id @default(cuid())
  title String  @unique
  image String?

  products ProductAllergen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Products
// =====================

model Product {
  id    String  @id @default(cuid())
  title String
  image String?
  note  String?

  calories      Float?
  protein       Float?
  fat           Float?
  carbs         Float?
  glycemicIndex Float?

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  recipeProducts RecipeProduct[]
  allergens      ProductAllergen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeProduct {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  title     String
  amount    Float?
  unit      String?
  note      String?
  sortOrder Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductAllergen {
  productId  String
  allergenId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  allergen Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([productId, allergenId])
}

// =====================
// Recipe relations
// =====================

model RecipeCategory {
  recipeId   String
  categoryId String

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([recipeId, categoryId])
}

model RecipeTag {
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([recipeId, tagId])
}

model RecipeImage {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  url       String
  alt       String?
  sortOrder Int?
  isCover   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeStep {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  title       String?
  description String
  image       String?
  sortOrder   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Favorites / Comments / Reactions
// =====================

model Favorite {
  id String @id @default(cuid())

  userId   String
  recipeId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, recipeId])
}

model Comment {
  id      String  @id @default(cuid())
  title   String?
  image   String?
  content String?

  authorId String
  recipeId String

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  reactions CommentReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommentReaction {
  id String @id @default(cuid())

  type ReactionType

  authorId  String
  commentId String

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, commentId])
}

model RecipeReaction {
  id String @id @default(cuid())

  type ReactionType

  authorId String
  recipeId String

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, recipeId])
}
