// ======================================================
// Prisma Client
// ======================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// Enums
// =====================

enum RecipeVisibility {
  PUBLIC
  PRIVATE
}

enum RecipeDifficulty {
  EASY
  MEDIUM
  HARD
}

enum RecipeSourceType {
  OWN
  WEBSITE
  VIDEO
  SOCIAL_MEDIA
  SCREENSHOT
  PDF
  BOOK
  OTHER
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum Locale {
  UK
  EN
}

// =====================
// Users
// =====================

model User {
  id             String  @id @default(cuid())
  email          String  @unique
  name           String?
  shortName      String?
  image          String?
  recipesCount   Int     @default(0)
  favoritesCount Int     @default(0)

  recipes          Recipe[]
  products         Product[]
  favorites        Favorite[]
  comments         Comment[]
  commentReactions CommentReaction[]
  recipeReactions  RecipeReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Recipes
// =====================

model Recipe {
  id          String  @id @default(cuid())
  title       String
  slug        String
  description String?
  notes       String?

  prepTimeSec Int?
  cookTimeSec Int?

  coverImage String?

  visibility RecipeVisibility  @default(PRIVATE)
  difficulty RecipeDifficulty?

  sourceType RecipeSourceType @default(OWN)
  sourceUrl  String?
  sourceName String?

  originalAuthorName String?
  originalAuthorUrl  String?

  calories      Float?
  protein       Float?
  fat           Float?
  carbs         Float?
  glycemicIndex Float?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  categories  RecipeCategory[]
  tags        RecipeTag[]
  images      RecipeImage[]
  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  favorites   Favorite[]
  comments    Comment[]
  reactions   RecipeReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, slug])
}

// =====================
// Categories / Tags / Allergens
// =====================

model Category {
  id    String  @id @default(cuid())
  title String  @unique
  slug  String  @unique
  image String?

  translations CategoryTranslation[]
  recipes      RecipeCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryTranslation {
  id         String @id @default(cuid())
  categoryId String
  locale     Locale
  title      String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
}

model Tag {
  id    String  @id @default(cuid())
  title String  @unique
  slug  String  @unique
  image String?

  translations TagTranslation[]
  recipes      RecipeTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TagTranslation {
  id     String @id @default(cuid())
  tagId  String
  locale Locale
  title  String

  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
}

model Allergen {
  id    String  @id @default(cuid())
  title String  @unique
  slug  String  @unique
  image String?

  translations AllergenTranslation[]
  ingredients  IngredientAllergen[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AllergenTranslation {
  id         String @id @default(cuid())
  allergenId String
  locale     Locale
  title      String

  allergen Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@unique([allergenId, locale])
}

// =====================
// Ingredients / Products
// =====================

model Ingredient {
  id    String  @id @default(cuid())
  title String  @unique
  slug  String  @unique
  image String?
  note  String?

  calories      Float?
  protein       Float?
  fat           Float?
  carbs         Float?
  glycemicIndex Float?

  translations      IngredientTranslation[]
  allergens         IngredientAllergen[]
  products          Product[]
  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngredientTranslation {
  id           String @id @default(cuid())
  ingredientId String
  locale       Locale
  title        String

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([ingredientId, locale])
}

model Product {
  id    String  @id @default(cuid())
  title String
  slug  String
  image String?
  note  String?

  calories      Float?
  protein       Float?
  fat           Float?
  carbs         Float?
  glycemicIndex Float?

  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  recipeIngredients RecipeIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, slug])
}

model IngredientAllergen {
  ingredientId String
  allergenId   String

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  allergen   Allergen   @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([ingredientId, allergenId])
}

// =====================
// Recipe Ingredients / Steps / Images
// =====================

model RecipeIngredient {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: SetNull)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  title       String
  amountGrams Float?
  note        String?
  sortOrder   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeStep {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  title       String?
  description String
  image       String?
  sortOrder   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecipeImage {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  url       String
  alt       String?
  sortOrder Int?
  isCover   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================
// Recipe Relations
// =====================

model RecipeCategory {
  recipeId   String
  categoryId String

  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([recipeId, categoryId])
}

model RecipeTag {
  recipeId String
  tagId    String

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([recipeId, tagId])
}

// =====================
// Favorites / Comments / Reactions
// =====================

model Favorite {
  id String @id @default(cuid())

  userId   String
  recipeId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, recipeId])
}

model Comment {
  id      String  @id @default(cuid())
  title   String?
  image   String?
  content String?

  authorId String
  recipeId String

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  reactions CommentReaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommentReaction {
  id String @id @default(cuid())

  type ReactionType

  authorId  String
  commentId String

  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, commentId])
}

model RecipeReaction {
  id String @id @default(cuid())

  type ReactionType

  authorId String
  recipeId String

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([authorId, recipeId])
}
